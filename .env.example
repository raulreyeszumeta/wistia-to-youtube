# Wistia
WISTIA_API_TOKEN=your_wistia_api_token_here

# YouTube OAuth2 (from Google Cloud Console)
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# Anthropic (for AI-powered SEO optimization)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Notion (optional — for weekly YouTube reports)
NOTION_API_KEY=your_notion_api_key_here
NOTION_REPORTS_DB=your_notion_reports_database_id
NOTION_TASKS_DB=your_notion_tasks_database_id

# Company / SEO context (used in AI-generated descriptions)
COMPANY_NAME=Your Company
COMPANY_WEBSITE=https://yourcompany.com
COMPANY_LOCATION=City, State
COMPANY_FOCUS=video content, industry interviews, business insights
PLAYLIST_SUFFIX= | Your Company

# YouTube channel (optional — for channel verification and reporting)
YOUTUBE_CHANNEL_HANDLE=yourchannelhandle
YOUTUBE_BRAND_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx

# Optional: set to "true" to skip actual uploads (preview mode)
DRY_RUN=true
